# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin Group Settings
ADMIN_GROUP_ID=-1001234567890

# Admin Group Topic/Thread IDs
TOPIC_NEW_CONNECTION=1
TOPIC_COMMANDS=2
TOPIC_ERRORS=3
TOPIC_AUTH=4
TOPIC_DISCONNECTIONS=5

# Redis (for Celery task queue)
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=sqlite:///data/bot.db

# Security
SECRET_KEY=change_this_to_a_random_secret_key_32chars

# SSH Keep-Alive interval (seconds)
SSH_KEEPALIVE_INTERVAL=30

# Max output length per message (Telegram limit is 4096)
MAX_OUTPUT_LENGTH=3500

# Session timeout (seconds of inactivity before auto-disconnect)
SESSION_TIMEOUT=1800
